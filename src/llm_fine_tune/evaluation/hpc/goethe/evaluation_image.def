# Apptainer build recipe for the Phase-2 execution sandbox.
#
# Phase 2 only compiles + runs the executable code (g++ / javac / python3) and scores it —
# it does NOT run the model and does NOT need bigcode (that's Phase 1, in the ROCm venv).
# So we base on a small python:3.11 image instead of bigcode's ~20-language MultiPL-E image,
# which built in hours on PanFS. This builds in minutes and matches the package's Python.
#
# Build (on a compute node, from $REPO_DIR):
#   apptainer build "$WORK_DIR/images/evaluation.sif" \
#       src/llm_fine_tune/evaluation/hpc/goethe/evaluation_image.def
#
# Run at evaluation time with --net none (no outbound network during execution).

Bootstrap: docker
From: python:3.11-slim-bookworm

%files
    # Only what pip needs to build the package — not .venv/output/data/.git.
    pyproject.toml /opt/llm-fine-tune/pyproject.toml
    README.md /opt/llm-fine-tune/README.md
    src /opt/llm-fine-tune/src

%post
    apt-get update && apt-get install -y --no-install-recommends \
        g++ \
        openjdk-17-jdk-headless \
        && rm -rf /var/lib/apt/lists/*
    # polars: read the evaluation parquet in the Phase-2 scorer. tqdm: light import.
    pip install --no-cache-dir polars tqdm
    # --no-deps: the scorer's import chain is polars + execution harness + stdlib only.
    pip install --no-cache-dir --no-deps /opt/llm-fine-tune

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
