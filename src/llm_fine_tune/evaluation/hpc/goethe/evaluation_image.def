# Apptainer build recipe for the evaluation container.
#
# Extends the MultiPL-E toolchain image (which has g++, javac, java, python3)
# with the llm-fine-tune package so the evaluation core is importable.
#
# Build (on a node with internet access, from $REPO_DIR):
#   apptainer build "$WORK_DIR/images/evaluation.sif" \
#       src/llm_fine_tune/evaluation/hpc/goethe/evaluation_image.def
#
# The container is --net none at run time (no outbound network during execution).

Bootstrap: docker
From: ghcr.io/bigcode-project/evaluation-harness-multiple

%post
    # The execution sandbox only runs the executable_code_snippet_from_llm_response
    # (g++/javac/python from the base image) and imports the evaluation modules.
    # bigcode-eval + transformers/datasets are already in the base image, so install
    # the package with --no-deps and add only the light runtime imports it pulls in
    # (polars for loaders/report, tqdm). This keeps the .sif lean and avoids churning
    # the base image's pinned ML stack.
    pip install --no-cache-dir polars tqdm
    pip install --no-cache-dir --no-deps /opt/llm-fine-tune

%files
    # Copy only what pip needs to build the package — not .venv/output/data/.git,
    # which would bloat the build context and bake gigabytes into the .sif.
    pyproject.toml /opt/llm-fine-tune/pyproject.toml
    README.md /opt/llm-fine-tune/README.md
    src /opt/llm-fine-tune/src

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
