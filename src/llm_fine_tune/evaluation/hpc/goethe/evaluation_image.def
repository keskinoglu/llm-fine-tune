# Apptainer build recipe for the Phase-2 execution sandbox.
#
# Phase 2 only compiles + runs code (g++/javac/python3) and scores it — no model, no bigcode
# (that's Phase 1). Hence a small python:3.11 base, not bigcode's heavy MultiPL-E image.
#
# Build (on a compute node, from $REPO_DIR) — --sandbox (directory), since this account can't
# pack a .sif under proot (no /etc/subuid; mksquashfs fails). See submit-evaluation-setup.sh.
#   apptainer build --sandbox "$WORK_DIR/images/evaluation" \
#       src/llm_fine_tune/evaluation/hpc/goethe/evaluation_image.def
#
# Run at evaluation time with --net --network none (no outbound network during execution).

Bootstrap: docker
From: python:3.11-slim-bookworm

%files
    # Only what pip needs to build the package — not .venv/output/data/.git.
    pyproject.toml /opt/llm-fine-tune/pyproject.toml
    README.md /opt/llm-fine-tune/README.md
    src /opt/llm-fine-tune/src

%post
    apt-get update && apt-get install -y --no-install-recommends \
        g++ \
        openjdk-17-jdk-headless \
        rustc \
        golang-go \
        && rm -rf /var/lib/apt/lists/*
    # MultiPL-E java prompts import org.javatuples.* (tuple return types); put the jar where
    # execution.py's java classpath expects it. Fetched with the base image's python (no curl/wget).
    python -c "import urllib.request; urllib.request.urlretrieve('https://repo1.maven.org/maven2/org/javatuples/javatuples/1.2/javatuples-1.2.jar', '/opt/javatuples.jar')"
    # polars: read the evaluation parquet in the Phase-2 scorer. tqdm: light import.
    pip install --no-cache-dir polars tqdm
    # --no-deps: the scorer's import chain is polars + execution harness + stdlib only.
    pip install --no-cache-dir --no-deps /opt/llm-fine-tune

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
